(* Static code snippets                                                *)
(* ================================================================== *)

let hero_name = Signal.make "world"

let hero_shout =
  Computed.make (fun () -> String.uppercase_ascii (Signal.get hero_name))

let hero_code =
  {|open Reativa
open Reativa.View.Mlx

let name = Signal.make "world"
let shout = Computed.make (fun () -> String.uppercase_ascii (Signal.get name))

let () =
  View.mount_by_id "app"
    <section>
      <input
        value=(Signal.get name)
        onInput=(fun ev -> Signal.set name (Dom.target_value ev))
      />
      <h1>("Hello, ") (Signal.get shout) ("!")</h1>
    </section>|}

let install_code = {|opam pin add reativa https://github.com/brnrdog/reativa.git|}

let dune_project_code =
  {|(lang dune 3.16)

(using melange 0.1)

(dialect
 (name mlx)
 (implementation
  (extension mlx)
  (merlin_reader mlx)
  (preprocess
   (run mlx-pp %{input-file}))))|}

let dune_code =
  {|(melange.emit
 (target output)
 (libraries reativa)
 (preprocess
  (pps reativa.mlx_ppx melange.ppx))
 (module_systems es6))|}

let hello_code =
  {|open Reativa
open Reativa.View.Mlx

let () =
  View.mount_by_id "app"
    <main>
      <h1>("Hello from reativa!")</h1>
      <p>("This view mounted once - now wire in some signals.")</p>
    </main>|}

let component_code =
  {|module Greeting = struct
  let component = fun ~name ->
    <h2>("Hello, ") (name) ("!")</h2>
end

let view = <Greeting name="OCaml" />|}

let router_code =
  {|open Reativa
open Reativa.View.Mlx

let () =
  View.mount_by_id "app"
    <main>
      <nav>
        <Link href="/">("Home")</Link>
        <Link href="/users/42">("Ada")</Link>
      </nav>

      <Router>
        <Route path="/">
          <h1>("Home")</h1>
        </Route>

        <Route
          path="/users/:id"
          render=(fun matched ->
            <h1>
              ("User ")
              (Option.value ~default:"?" (Router.param matched "id"))
            </h1>)
        />

        <Route path="/old">
          <Redirect to_="/" />
        </Route>
      </Router>
    </main>|}

(* ================================================================== *)
(* The page                                                            *)
(* ================================================================== *)

let () =
  View.mount_by_id "app"
    <div className="site">
      <header className="topbar">
        <div className="topbar-inner">
          <a className="brand" href="#top">
            <span className="brand-mark">("r")</span>
            <span className="brand-name">("reativa")</span>
          </a>
          <nav className="topnav" aria_label="Primary">
            <a href="#why">("Why")</a>
            <a href="#examples">("Examples")</a>
            <a href="#start">("Get started")</a>
            <a href="#api">("API")</a>
          </nav>
          <a className="nav-github" href="https://github.com/brnrdog/reativa">
            ("GitHub")
          </a>
        </div>
      </header>

      <main className="page">
        <section id="top" className="hero">
          <div className="hero-copy">
            <p className="kicker">({js|OCaml · Melange · fine-grained signals|js})</p>
            <h1>
              ("Reactive web interfaces, ")
              <span className="accent">("written in OCaml.")</span>
            </h1>
            <p className="lede">
              ("reativa is a small UI library where state lives in signals and views are real DOM nodes. Everything mounts once - after that, only the text, attributes and regions that read a changed signal update. No virtual DOM, no diffing.")
            </p>
            <div className="hero-actions">
              <a className="btn primary" href="#start">("Get started")</a>
              <a className="btn ghost" href="#examples">("See it live")</a>
            </div>
            <ul className="hero-badges">
              <li>("No virtual DOM")</li>
              <li>("MIT licensed")</li>
              <li>("Experimental")</li>
            </ul>
          </div>
          <div className="hero-code">
            (code_panel ~id:"hero" ~file:"hello.mlx" ~lang:"ocaml" hero_code)
            <div className="hero-live">
              <span className="demo-tag">("Live demo")</span>
              <div className="hero-live-row">
                <input
                  className="field"
                  aria_label="Your name"
                  value=(Signal.get hero_name)
                  onInput=(fun ev -> Signal.set hero_name (Dom.target_value ev))
                />
                <p className="hero-live-out">
                  ("Hello, ") <strong>(Signal.get hero_shout)</strong> ("!")
                </p>
              </div>
              <p className="hero-note">
                ("This exact code is running here. Typing updates one text node - nothing else re-renders.")
              </p>
            </div>
          </div>
        </section>

        <section id="why" className="section">
          (section_head "Why reativa" "Fine-grained by construction"
             "The reactive model popularised by SolidJS, in idiomatic OCaml: a signal graph drives surgical DOM updates.")
          <div className="features">
            (feature "Mount once, update in place"
               "A view builds real DOM nodes exactly once. Afterwards, effects patch the specific text node, attribute or region that read a changed signal - there is no tree to diff.")
            (feature "Plain OCaml all the way down"
               "Signals, computeds and effects are ordinary typed OCaml values. The whole graph runs and tests natively with dune - the browser only enters the picture in the View layer.")
            (feature "Markup that infers reactivity"
               "Write JSX-like markup in .mlx files. Literals stay static, inline Signal.get reads are auto-tracked, and event handlers stay plain functions. The PPX wires the updates for you.")
          </div>
        </section>

        <section id="examples" className="section">
          (section_head "Examples" "Full code, running live"
             "Each block below is a complete program - copy it into an .mlx file and it compiles as-is. The demo beside it is that same code running on this page, because this site is itself built with reativa.")
          <div className="examples">
            (example ~id:"example-counter" ~title:"Counter"
               ~intro:"State is a Signal, derived state is a Computed. Reading them inline in markup makes that exact node reactive - the PPX auto-tracks eager Signal.get reads."
               ~file:"counter.mlx" ~code:counter_code counter_demo)
            (example ~id:"example-todos" ~title:"Todo list"
               ~intro:"View.ForEach reconciles a keyed list: rows keep their DOM nodes when items move or change elsewhere. The input is bound to a signal, so resetting it clears the field instantly."
               ~file:"todos.mlx" ~code:todos_code todos_demo)
            (example ~id:"example-show" ~title:"Conditional rendering"
               ~intro:"View.Show swaps a region on a boolean condition; View.Maybe renders the Some branch of an option. Both only rebuild when the branch actually changes."
               ~file:"conditional.mlx" ~code:show_code show_demo)
            (example ~id:"example-stopwatch" ~title:"Stopwatch"
               ~intro:"Effect.run re-runs when a tracked read changes and can return a cleanup. Flipping the signal starts or stops the interval - the cleanup always runs before the next effect."
               ~file:"stopwatch.mlx" ~code:stopwatch_code stopwatch_demo)
            (example ~id:"example-weather" ~title:"Fetch the weather"
               ~intro:"Async data is just another signal write. A variant signal models idle, loading, loaded and failed; clicking fetches a random city from the free Open-Meteo API, and View.tracked re-renders the region on each state change."
               ~file:"weather.mlx" ~code:weather_code weather_demo)
          </div>
        </section>

        <section id="start" className="section">
          (section_head "Get started" "From zero to a mounted view"
             "reativa compiles to JavaScript with Melange and uses the mlx dialect for JSX-like markup. Four short steps.")
          <div className="steps">
            (step "1" "Install the library"
               "reativa targets OCaml 4.14+ and dune 3.16+, and depends on melange, mlx and ppxlib. Pin it straight from GitHub into your switch."
               (code_panel ~id:"install" ~file:"shell" ~lang:"shell" install_code))
            (step "2" "Teach dune the mlx dialect"
               "The mlx preprocessor turns JSX-like markup in .mlx files into regular OCaml before compilation. Declare the dialect once in dune-project."
               (code_panel ~id:"dune-project" ~file:"dune-project" ~lang:"dune"
                  dune_project_code))
            (step "3" "Emit JavaScript"
               "Add a melange.emit stanza with reativa's PPX. dune build @melange writes ES modules under _build - bundle the emitted app.js with esbuild or Vite."
               (code_panel ~id:"dune-stanza" ~file:"src/dune" ~lang:"dune" dune_code))
            (step "4" "Write your first view"
               "Mount into any element - here, <div id=\"app\"></div> in your index.html. Static views are created once; from there, inline signal reads make exact nodes reactive - like the hero demo at the top of this page."
               (code_panel ~id:"hello" ~file:"app.mlx" ~lang:"ocaml" hello_code))
          </div>
        </section>

        <section id="api" className="section">
          (section_head "API reference" "The whole surface, at a glance"
             "Five small modules under the Reativa namespace. The signal graph is plain OCaml; View and Router target the browser through Melange.")

          (api_group ~id:"api-signal" ~name:"Signal"
             ~blurb:"Mutable reactive state - the root of the graph. Reads with get are tracked by whatever computed, effect or reactive view is currently running."
             [
               api_row
                 "make : ?name:string -> ?equals:('a -> 'a -> bool) -> 'a -> 'a Signal.t"
                 "Create a signal from an initial value. equals decides whether a write is a real change (default: physical equality).";
               api_row "get : 'a Signal.t -> 'a"
                 "Read the current value and track it as a dependency of the running computed, effect or reactive view.";
               api_row "peek : 'a Signal.t -> 'a"
                 "Read without creating a dependency. Use inside event handlers and effects for reads that should not re-trigger.";
               api_row "set : 'a Signal.t -> 'a -> unit"
                 "Write a new value. Subscribers only re-run when equals says the value actually changed.";
               api_row "update : 'a Signal.t -> ('a -> 'a) -> unit"
                 "Write by transforming the current value.";
               api_row "batch : (unit -> 'a) -> 'a"
                 "Group several writes into one flush - dependents update once at the end instead of after every write.";
               api_row "untrack : (unit -> 'a) -> 'a"
                 "Run a function with dependency tracking suspended.";
             ])

          (api_group ~id:"api-computed" ~name:"Computed"
             ~blurb:"Lazy derived signals. A computed tracks every Signal.get made while computing and refreshes when a dependency changes - reads and caching are glitch-free."
             [
               api_row
                 "make : ?name:string -> ?equals:('a -> 'a -> bool) -> (unit -> 'a) -> 'a Signal.t"
                 "Derive a read-only signal. Read it with Signal.get or Signal.peek like any other signal. Pass ~equals to stop downstream work when the derived value is unchanged.";
               api_row "dispose : 'a Signal.t -> unit"
                 "Detach a computed from its dependencies; it will no longer update.";
             ])

          (api_group ~id:"api-effect" ~name:"Effect"
             ~blurb:"Tracked side effects. The body runs immediately, then re-runs whenever a signal it read changes. Return Some cleanup to run teardown before each re-run and on dispose."
             [
               api_row
                 "run : ?name:string -> (unit -> (unit -> unit) option) -> unit"
                 "Run a tracked effect for the lifetime of the page.";
               api_row
                 "run_with_disposer : ?name:string -> (unit -> (unit -> unit) option) -> Effect.disposer"
                 "Like run, but returns { dispose : unit -> unit } so the effect can be stopped manually.";
             ])

          (api_group ~id:"api-view" ~name:"View"
             ~blurb:"The DOM layer. A View.t describes real nodes; mounting creates them once and wires an effect for every reactive part. Use the mlx markup or the plain constructors - they build the same thing."
             [
               api_row "mount_by_id : string -> View.t -> unit"
                 "Render a view into the element with the given id (View.mount takes a Dom.t container directly).";
               api_row "static / dynamic / signal"
                 "Value wrappers for props and text: static values are set once; dynamic thunks and signal reads update in place. In .mlx files the PPX infers these - see the rules below.";
               api_row "text / int / float : 'a value -> View.t"
                 "Reactive text leaves. Optional in .mlx markup - bare literals and expressions render directly.";
               api_row "tracked : (unit -> View.t) -> View.t"
                 "A region that rebuilds its whole subtree when any signal read while building it changes. Reach for it when the structure changes; prefer inline reads when only text or attributes do.";
               api_row "show : ?fallback:View.t -> (unit -> bool) -> View.t -> View.t"
                 "Render a view while the condition holds, otherwise the fallback. Also available as <View.Show condition fallback>.";
               api_row
                 "maybe : ?fallback:View.t -> (unit -> 'a option) -> ('a -> View.t) -> View.t"
                 "Render from the Some branch of an option. Also available as <View.Maybe value render fallback />.";
               api_row "for_ : (unit -> 'a list) -> ('a -> View.t) -> View.t"
                 "Map a reactive list to views, re-rendering the whole list on change. <View.ForEach items render /> without a key does the same.";
               api_row
                 "for_with_key : (unit -> 'a list) -> key:('a -> string) -> ('a Signal.t -> View.t) -> View.t"
                 "Keyed reconciliation: rows keep their DOM nodes and effects across updates; each row reads its latest item from a signal. In markup, pass key to <View.ForEach items key render />.";
               api_row "Attr / On"
                 "Escape hatches for the constructor style: Attr.className, Attr.value, Attr.disabled, custom Attr.make - and On.click, On.input, On.keydown and friends.";
             ])

          <article className="api-group" id="api-mlx">
            <h3><code>("mlx inference rules")</code></h3>
            <p className="api-blurb">
              ("In .mlx markup, props and children need no value wrappers - the PPX picks static or dynamic from the shape of the expression:")
            </p>
            <ul className="rules">
              <li>
                <strong>("Literals")</strong>
                (" - strings, ints and floats become static leaves, created once.")
              </li>
              <li>
                <strong>("Inline reads")</strong>
                (" - an eager Signal.get is auto-thunked and tracked; the exact node updates when the signal changes.")
              </li>
              <li>
                <strong>("Thunks")</strong>
                (" - (fun () -> ...) stays a dynamic value, tracked the same way.")
              </li>
              <li>
                <strong>("Signal.peek")</strong>
                (" - never counts as a read; peek-only expressions stay static.")
              </li>
              <li>
                <strong>("Nested funs")</strong>
                (" - reads inside event handlers and callbacks are left alone; handlers are never thunked.")
              </li>
              <li>
                <strong>("Anything else")</strong>
                (" - plain values render through View.child at runtime; already-built views pass through untouched.")
              </li>
            </ul>
            <p className="api-blurb">
              ("Capitalized tags are components: define component in a module and use the module name as a tag. Inference is syntax-based, so a read hidden behind a variable or helper is not detected - wrap those explicitly with static, dynamic or signal.")
            </p>
            (code_panel ~id:"component" ~file:"greeting.mlx" ~lang:"ocaml"
               component_code)
          </article>

          (api_group ~id:"api-router" ~name:"Router"
             ~blurb:"Browser SPA navigation: a reactive location signal, history wrappers, link interception and pure route matching. Patterns support static segments, :params and a trailing * wildcard."
             [
               api_row "location : unit -> Router.location Signal.t"
                 "The current browser location as a signal - pathname, search, hash, origin and optional history state. Reading it in a tracked scope subscribes to navigation.";
               api_row
                 "navigate : ?replace:bool -> ?state:Router.state -> string -> unit -> unit"
                 "Programmatic navigation via pushState (or replaceState with ~replace:true). back, forward and go wrap the history API.";
               api_row "param : Router.route_match -> string -> string option"
                 "Read a :param captured by the matched route pattern.";
               api_row "match_path : string -> string -> Router.route_match option"
                 "Pure matching of a pattern against a pathname - usable (and tested) natively.";
               api_row "is_active : ?exact:bool -> string -> bool"
                 "Whether the current location matches an href - handy for nav styling.";
               api_row "state / state_value"
                 "Encode a value as history state for navigate ~state, and decode it back from location.";
               api_row "<Router> <Route> <Link> <Redirect>"
                 "The markup primitives: Router renders the first matching Route child; Route takes path and children or render; Link intercepts same-origin clicks; Redirect navigates on render.";
             ])

          <div className="router-example">
            (code_panel ~id:"router" ~file:"router.mlx" ~lang:"ocaml" router_code)
            <p className="api-note">
              ("Routing needs a host that serves index.html for every path - run it locally with any SPA dev server. Constructor-style equivalents exist too: Router.route, Router.outlet, Router.link and Router.redirect.")
            </p>
          </div>
        </section>
      </main>

      <footer className="footer">
        <div className="footer-inner">
          <p>
