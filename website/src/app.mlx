(* The reativa documentation site — written in reativa itself.

   Every live demo on this page is the library running for real: signals hold
   the state, and the exact text nodes, attributes and regions that read them
   update in place. Code blocks are static views; a tiny highlighter in
   main.js colors them once after mount. *)

open Reativa
open Reativa.View.Mlx

(* ----- browser bindings used only by the docs site ----- *)

external copy_text : string -> unit = "writeText"
  [@@mel.scope ("navigator", "clipboard")]

external set_timeout : (unit -> unit) -> int -> unit = "setTimeout"
external set_interval : (unit -> unit) -> int -> float = "setInterval"
external clear_interval : float -> unit = "clearInterval"

(* ----- copy-to-clipboard feedback ----- *)

let copied = Signal.make ""

let copy_code id source =
  (try copy_text source with _ -> ());
  Signal.set copied id;
  set_timeout
    (fun () -> if Signal.peek copied = id then Signal.set copied "")
    1600

(* ----- building blocks ----- *)

let code_panel ~id ~file ~lang source =
  <figure className="code-panel">
    <figcaption className="code-panel-bar">
      <span className="code-file">(file)</span>
      <button
        className=(if Signal.get copied = id then "copy-btn is-copied" else "copy-btn")
        aria_label="Copy code to clipboard"
        onClick=(fun _ -> copy_code id source)
      >
        (if Signal.get copied = id then "Copied!" else "Copy")
      </button>
    </figcaption>
    <pre className=("code-body " ^ lang)><code>(source)</code></pre>
  </figure>

let section_head kicker title lede =
  <header className="section-head">
    <p className="kicker">(kicker)</p>
    <h2>(title)</h2>
    <p className="lede">(lede)</p>
  </header>

let feature title body =
  <article className="feature">
    <h3>(title)</h3>
    <p>(body)</p>
  </article>

let example ~id ~title ~intro ~file ~code demo =
  <article id=(id) className="example">
    <div className="example-info">
      <h3>(title)</h3>
      <p>(intro)</p>
    </div>
    <div className="example-panes">
      (code_panel ~id ~file ~lang:"ocaml" code)
      <aside className="example-demo">
        <span className="demo-tag">("Live demo")</span>
        <div className="demo-stage">(demo)</div>
      </aside>
    </div>
  </article>

let api_row signature description =
  <div className="api-row">
    <dt><code>(signature)</code></dt>
    <dd>(description)</dd>
  </div>

let api_group ~id ~name ~blurb rows =
  <article id=(id) className="api-group">
    <h3><code>(name)</code></h3>
    <p className="api-blurb">(blurb)</p>
    <dl className="api-rows">(View.fragment rows)</dl>
  </article>

let step number title body content =
  <article className="step">
    <div className="step-head">
      <span className="step-num">(number)</span>
      <div className="step-copy">
        <h3>(title)</h3>
        <p>(body)</p>
      </div>
    </div>
    (content)
  </article>

(* ================================================================== *)
(* Example 1 — counter: signals and computed values                    *)
(* ================================================================== *)

let count = Signal.make 0
let doubled = Computed.make (fun () -> Signal.get count * 2)

let counter_code =
  {|open Reativa
open Reativa.View.Mlx

let count = Signal.make 0
let doubled = Computed.make (fun () -> Signal.get count * 2)

let () =
  View.mount_by_id "app"
    <div className="counter">
      <p className="value">(Signal.get count)</p>
      <p>("doubled is ") (Signal.get doubled)</p>
      <div className="row">
        <button onClick=(fun _ -> Signal.update count (fun n -> n - 1))>
          ("-1")
        </button>
        <button onClick=(fun _ -> Signal.update count (fun n -> n + 1))>
          ("+1")
        </button>
        <button onClick=(fun _ -> Signal.set count 0)>("Reset")</button>
      </div>
    </div>|}

let counter_demo =
  <div className="counter-demo">
    <p className="big-value">(Signal.get count)</p>
    <p className="demo-sub">
      ("doubled is ") <strong>(Signal.get doubled)</strong>
    </p>
    <div className="btn-row">
      <button
        className="btn small"
        onClick=(fun _ -> Signal.update count (fun n -> n - 1))
      >
        ("-1")
      </button>
      <button
        className="btn small"
        onClick=(fun _ -> Signal.update count (fun n -> n + 1))
      >
        ("+1")
      </button>
      <button className="btn small ghost" onClick=(fun _ -> Signal.set count 0)>
        ("Reset")
      </button>
    </div>
  </div>

(* ================================================================== *)
(* Example 2 — todos: keyed lists, forms and reactive inputs           *)
(* ================================================================== *)

type todo = { todo_id : int; title : string; done_ : bool }

let todos =
  Signal.make
    [
      { todo_id = 1; title = "Read the signals guide"; done_ = true };
      { todo_id = 2; title = "Build something reactive"; done_ = false };
    ]

let next_id = Signal.make 3
let draft = Signal.make ""

let remaining =
  Computed.make (fun () ->
    Signal.get todos |> List.filter (fun t -> not t.done_) |> List.length)

let add_todo ev =
  Dom.prevent_default ev;
  let title = String.trim (Signal.peek draft) in
  if title <> "" then begin
    let todo_id = Signal.peek next_id in
    Signal.update todos (fun items ->
      items @ [ { todo_id; title; done_ = false } ]);
    Signal.set next_id (todo_id + 1);
    Signal.set draft ""
  end

let toggle_todo id =
  Signal.update todos (fun items ->
    List.map
      (fun t -> if t.todo_id = id then { t with done_ = not t.done_ } else t)
      items)

let todos_code =
  {|open Reativa
open Reativa.View.Mlx

type todo = { id : int; title : string; done_ : bool }

let todos =
  Signal.make
    [
      { id = 1; title = "Read the signals guide"; done_ = true };
      { id = 2; title = "Build something reactive"; done_ = false };
    ]

let next_id = Signal.make 3
let draft = Signal.make ""

let remaining =
  Computed.make (fun () ->
    Signal.get todos |> List.filter (fun t -> not t.done_) |> List.length)

let add_todo ev =
  Dom.prevent_default ev;
  let title = String.trim (Signal.peek draft) in
  if title <> "" then begin
    let id = Signal.peek next_id in
    Signal.update todos (fun items -> items @ [ { id; title; done_ = false } ]);
    Signal.set next_id (id + 1);
    Signal.set draft ""
  end

let toggle id =
  Signal.update todos (fun items ->
    List.map
      (fun t -> if t.id = id then { t with done_ = not t.done_ } else t)
      items)

let () =
  View.mount_by_id "app"
    <div className="todos">
      <form onSubmit=add_todo>
        <input
          placeholder="What needs doing?"
          value=(Signal.get draft)
          onInput=(fun ev -> Signal.set draft (Dom.target_value ev))
        />
        <button disabled=(String.trim (Signal.get draft) = "")>("Add")</button>
      </form>

      <ul>
        <View.ForEach
          items=(fun () -> Signal.get todos)
          key=(fun t -> string_of_int t.id)
          render=(fun t ->
            <li>
              <label>
                <input
                  type_="checkbox"
                  checked=(t.done_)
                  onChange=(fun _ -> toggle t.id)
                />
                <span>(t.title)</span>
              </label>
            </li>)
        />
      </ul>

      <p>(Signal.get remaining) (" left to do")</p>
    </div>|}

let todos_demo =
  <div className="todo-demo">
    <form className="todo-form" onSubmit=add_todo>
      <input
        className="field"
        placeholder="What needs doing?"
        value=(Signal.get draft)
        onInput=(fun ev -> Signal.set draft (Dom.target_value ev))
      />
      <button
        className="btn small"
        disabled=(String.trim (Signal.get draft) = "")
      >
        ("Add")
      </button>
    </form>
    <ul className="todo-items">
      <View.ForEach
        items=(fun () -> Signal.get todos)
        key=(fun t -> string_of_int t.todo_id)
        render=(fun t ->
          <li className="todo-item">
            <label className=(if t.done_ then "todo-label done" else "todo-label")>
              <input
                type_="checkbox"
                checked=(t.done_)
                onChange=(fun _ -> toggle_todo t.todo_id)
              />
              <span>(t.title)</span>
            </label>
          </li>)
      />
    </ul>
    <p className="demo-sub">(Signal.get remaining) (" left to do")</p>
  </div>

(* ================================================================== *)
(* Example 3 — conditional rendering with Show and Maybe               *)
(* ================================================================== *)

let logged_in = Signal.make false
let topic : string option Signal.t = Signal.make None

let show_code =
  {|open Reativa
open Reativa.View.Mlx

let logged_in = Signal.make false
let topic : string option Signal.t = Signal.make None

let () =
  View.mount_by_id "app"
    <div className="panel">
      <div className="row">
        <button onClick=(fun _ -> Signal.update logged_in not)>
          (if Signal.get logged_in then "Sign out" else "Sign in")
        </button>
        <button onClick=(fun _ -> Signal.set topic (Some "signals"))>
          ("Pick a topic")
        </button>
        <button onClick=(fun _ -> Signal.set topic None)>("Clear")</button>
      </div>

      <View.Show
        condition=(fun () -> Signal.get logged_in)
        fallback=(<p>("Signed out. Sign in to see your greeting.")</p>)
      >
        <p>("Welcome back!")</p>
      </View.Show>

      <View.Maybe
        value=(fun () -> Signal.get topic)
        fallback=(<p>("No topic selected.")</p>)
        render=(fun topic ->
          <p>("Reading about ") <strong>(topic)</strong> (".")</p>)
      />
    </div>|}

let show_demo =
  <div className="show-demo">
    <div className="btn-row">
      <button className="btn small" onClick=(fun _ -> Signal.update logged_in not)>
        (if Signal.get logged_in then "Sign out" else "Sign in")
      </button>
      <button
        className="btn small ghost"
        onClick=(fun _ -> Signal.set topic (Some "signals"))
      >
        ("Pick a topic")
      </button>
      <button className="btn small ghost" onClick=(fun _ -> Signal.set topic None)>
        ("Clear")
      </button>
    </div>
    <View.Show
      condition=(fun () -> Signal.get logged_in)
      fallback=(<p className="status muted">("Signed out. Sign in to see your greeting.")</p>)
    >
      <p className="status">("Welcome back!")</p>
    </View.Show>
    <View.Maybe
      value=(fun () -> Signal.get topic)
      fallback=(<p className="status muted">("No topic selected.")</p>)
      render=(fun topic ->
        <p className="status">("Reading about ") <strong>(topic)</strong> (".")</p>)
    />
  </div>

(* ================================================================== *)
(* Example 4 — stopwatch: effects with cleanup                         *)
(* ================================================================== *)

let tenths = Signal.make 0
let running = Signal.make false

let () =
  Effect.run (fun () ->
    if Signal.get running then begin
      let id =
        set_interval (fun () -> Signal.update tenths (fun n -> n + 1)) 100
      in
      Some (fun () -> clear_interval id)
    end
    else None)

let stopwatch_code =
  {|open Reativa
open Reativa.View.Mlx

external set_interval : (unit -> unit) -> int -> float = "setInterval"
external clear_interval : float -> unit = "clearInterval"

let tenths = Signal.make 0
let running = Signal.make false

(* The effect re-runs when [running] flips. Its cleanup stops the
   previous interval first - that is the whole lifecycle. *)
let () =
  Effect.run (fun () ->
    if Signal.get running then begin
      let id =
        set_interval (fun () -> Signal.update tenths (fun n -> n + 1)) 100
      in
      Some (fun () -> clear_interval id)
    end
    else None)

let () =
  View.mount_by_id "app"
    <div className="stopwatch">
      <p className="time">
        (let n = Signal.get tenths in
         string_of_int (n / 10) ^ "." ^ string_of_int (n mod 10) ^ "s")
      </p>
      <div className="row">
        <button onClick=(fun _ -> Signal.update running not)>
          (if Signal.get running then "Pause" else "Start")
        </button>
        <button onClick=(fun _ -> Signal.set tenths 0)>("Reset")</button>
      </div>
    </div>|}

let stopwatch_demo =
  <div className="stopwatch-demo">
    <p className="big-value">
      (let n = Signal.get tenths in
       string_of_int (n / 10) ^ "." ^ string_of_int (n mod 10) ^ "s")
    </p>
    <div className="btn-row">
      <button className="btn small" onClick=(fun _ -> Signal.update running not)>
        (if Signal.get running then "Pause" else "Start")
      </button>
      <button className="btn small ghost" onClick=(fun _ -> Signal.set tenths 0)>
        ("Reset")
      </button>
    </div>
  </div>

(* ================================================================== *)
(* Example 5 — weather: fetching async data into signals               *)
(* ================================================================== *)

type response
type payload
type current

external fetch : string -> response Js.Promise.t = "fetch"
external json : response -> payload Js.Promise.t = "json" [@@mel.send]
external current_weather : payload -> current = "current_weather" [@@mel.get]
external temperature : current -> float = "temperature" [@@mel.get]
external windspeed : current -> float = "windspeed" [@@mel.get]
external random : unit -> float = "random" [@@mel.scope "Math"]

type city = { name : string; lat : string; lon : string }

let cities =
  [|
    { name = "Lisbon"; lat = "38.72"; lon = "-9.14" };
    { name = "Tokyo"; lat = "35.68"; lon = "139.69" };
    { name = "Nairobi"; lat = "-1.29"; lon = "36.82" };
    { name = "Reykjavik"; lat = "64.15"; lon = "-21.94" };
    { name = "Sydney"; lat = "-33.87"; lon = "151.21" };
    { name = "Cusco"; lat = "-13.53"; lon = "-71.97" };
  |]

type weather_state =
  | Idle
  | Loading of city
  | Loaded of city * float * float
  | Failed of city

let weather = Signal.make Idle

let fetch_weather _ =
  let city =
    cities.(int_of_float (random () *. float_of_int (Array.length cities)))
  in
  Signal.set weather (Loading city);
  let url =
    "https://api.open-meteo.com/v1/forecast?latitude=" ^ city.lat
    ^ "&longitude=" ^ city.lon ^ "&current_weather=true"
  in
  ignore
    (fetch url
    |> Js.Promise.then_ json
    |> Js.Promise.then_ (fun payload ->
         let current = current_weather payload in
         Signal.set weather
           (Loaded (city, temperature current, windspeed current));
         Js.Promise.resolve ())
    |> Js.Promise.catch (fun _ ->
         Signal.set weather (Failed city);
         Js.Promise.resolve ()))

let weather_code =
  {|open Reativa
open Reativa.View.Mlx

(* Bindings for fetch and the shape of the Open-Meteo response. *)
type response
type payload
type current

external fetch : string -> response Js.Promise.t = "fetch"
external json : response -> payload Js.Promise.t = "json" [@@mel.send]
external current_weather : payload -> current = "current_weather" [@@mel.get]
external temperature : current -> float = "temperature" [@@mel.get]
external windspeed : current -> float = "windspeed" [@@mel.get]
external random : unit -> float = "random" [@@mel.scope "Math"]

type city = { name : string; lat : string; lon : string }

let cities =
  [|
    { name = "Lisbon"; lat = "38.72"; lon = "-9.14" };
    { name = "Tokyo"; lat = "35.68"; lon = "139.69" };
    { name = "Nairobi"; lat = "-1.29"; lon = "36.82" };
    { name = "Reykjavik"; lat = "64.15"; lon = "-21.94" };
    { name = "Sydney"; lat = "-33.87"; lon = "151.21" };
    { name = "Cusco"; lat = "-13.53"; lon = "-71.97" };
  |]

type state =
  | Idle
  | Loading of city
  | Loaded of city * float * float
  | Failed of city

let weather = Signal.make Idle

let fetch_weather _ =
  let city =
    cities.(int_of_float (random () *. float_of_int (Array.length cities)))
  in
  Signal.set weather (Loading city);
  let url =
    "https://api.open-meteo.com/v1/forecast?latitude=" ^ city.lat
    ^ "&longitude=" ^ city.lon ^ "&current_weather=true"
  in
  ignore
    (fetch url
    |> Js.Promise.then_ json
    |> Js.Promise.then_ (fun payload ->
         let current = current_weather payload in
         Signal.set weather
           (Loaded (city, temperature current, windspeed current));
         Js.Promise.resolve ())
    |> Js.Promise.catch (fun _ ->
         Signal.set weather (Failed city);
         Js.Promise.resolve ()))

let () =
  View.mount_by_id "app"
    <div className="weather">
      <button onClick=fetch_weather>("Check a random city")</button>
      (View.tracked (fun () ->
         match Signal.get weather with
         | Idle -> <p>("Real weather, one click away.")</p>
         | Loading city -> <p>("Checking " ^ city.name ^ "...")</p>
         | Failed city ->
           <p>("Could not reach the service for " ^ city.name ^ ".")</p>
         | Loaded (city, temp, wind) ->
           <div>
             <h3>(city.name)</h3>
             <p>(temp) (" C now, wind ") (wind) (" km/h")</p>
           </div>))
    </div>|}

let weather_demo =
  <div className="weather-demo">
    <button className="btn small" onClick=fetch_weather>
      ("Check a random city")
    </button>
    (View.tracked (fun () ->
       match Signal.get weather with
       | Idle ->
         <p className="status muted">("Real weather, one click away.")</p>
       | Loading city ->
         <p className="status muted">("Checking " ^ city.name ^ "...")</p>
       | Failed city ->
         <p className="status muted">
           ("Could not reach the service for " ^ city.name ^ ".")
         </p>
       | Loaded (city, temp, wind) ->
         <div className="weather-card">
           <h3>(city.name)</h3>
           <p className="weather-line">
             <strong>(temp)</strong>
             (" C now, wind ")
             <strong>(wind)</strong>
             (" km/h")
           </p>
         </div>))
  </div>

