{
  "name": "reativa",
  "version": "1.1.0",
  "description": "Fine-grained reactive web interfaces for OCaml and Melange, powered by signals.",
  "scripts": {
    "build": "dune build @melange",
    "test": "dune test",
    "demo": "dune build @melange && npx --yes esbuild _build/default/demo/ui/output/demo/ui/app.js --bundle --format=esm --outfile=demo/ui/bundle.js",
    "demo:serve": "npm run demo && node scripts/serve-demo.mjs --root demo/ui",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "keywords": [
    "ocaml",
    "melange",
    "signals",
    "ui",
    "view",
    "jsx",
    "web",
    "reactivity",
    "state",
    "reactive"
  ],
  "author": "Bernardo Gurgel <brnrdog@hey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brnrdog/reativa.git"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.0"
  }
}
